<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.VideoHelper" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- No-UI theme for the invisible projection-consent shim launched from the floating button. -->
    <style name="Theme.Transparent" parent="android:Theme.Translucent.NoTitleBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>
